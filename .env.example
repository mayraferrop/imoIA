# WhatsApp
# Por defeito, o ImoScout usa o Baileys Bridge (gratuito, localhost:3000).
# Se preferir a API paga Whapi.Cloud, preencha o token abaixo.
WHAPI_TOKEN=
BRIDGE_URL=http://localhost:3000

# Anthropic (Claude Haiku)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Casafari (comparaveis e estatisticas)
# Obter API Token em: app.casafari.com > Settings > API > Generate Token
CASAFARI_API_TOKEN=

# SIR / Confidencial Imobiliario (precos de transacao reais)
SIR_USERNAME=
SIR_PASSWORD=

# Idealista (opcional — listings ativos)
IDEALISTA_CLIENT_ID=
IDEALISTA_CLIENT_SECRET=

# Base de Dados
DATABASE_URL=sqlite:///data/imoscout.db

# Configuracoes
MIN_CONFIDENCE=0.6
BATCH_SIZE=20
TIMEZONE=Europe/Lisbon
